# LLM 攻防靶场 · 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ---- DeepSeek 直连 ----
DEEPSEEK_API_KEY=sk-REPLACE-ME
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- OpenRouter 聚合（国产+国外小模型） ----
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Ollama 本地模型 ----
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=deepseek-r1:8b

# ---- Flask ----
SECRET_KEY=
PORT=5001

# ---- Agent 沙箱 ----
AGENT_USE_DOCKER=0
AGENT_DOCKER_IMAGE=ai-security-range-agent-sandbox
